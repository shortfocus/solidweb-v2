---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import WhatWeDo from "@/components/WhatWeDo.astro";
import OurStrength from "@/components/OurStrength.astro";
import OurProjects from "@/components/OurProjects.astro";
import Review from "@/components/Review.astro";
import FAQ from "@/components/FAQ.astro";
import { siteConfig } from "@/config/site.config";
const site = Astro.site;
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: siteConfig.faq.items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
const webPageLd =
  site
    ? {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": `${site}/#webpage`,
        name: siteConfig.name,
        description: siteConfig.description,
        url: String(site),
        inLanguage: "ko-KR",
        isPartOf: { "@id": `${site}/#website` },
        about: { "@id": `${site}/#organization` },
      }
    : null;
---

<BaseLayout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    {webPageLd && (
      <script type="application/ld+json" set:html={JSON.stringify(webPageLd)} />
    )}
  </Fragment>
  <Hero />
  <WhatWeDo />
  <OurStrength />
  <OurProjects />
  <Review />
  <FAQ />
</BaseLayout>
