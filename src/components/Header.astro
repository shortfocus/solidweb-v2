---
import { siteConfig } from "@/config/site.config";
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-[#0D0D0D]">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="font-logo text-xl font-bold text-white sm:text-2xl">
      {siteConfig.name}
    </a>

    <nav class="hidden items-center gap-8 text-sm text-slate-300 md:flex">
      <a
        href="#contact"
        class="rounded border border-slate-500 px-4 py-2 text-slate-200 hover:border-slate-400 hover:bg-slate-800/50 transition"
      >
        {siteConfig.nav.consult}
      </a>
    </nav>

    <!-- 모바일: 햄버거 + 상담 신청 -->
    <div class="flex items-center gap-3 md:hidden">
      <a
        href="#contact"
        class="rounded border border-slate-500 px-3 py-1.5 text-sm text-slate-200"
      >
        {siteConfig.nav.consult}
      </a>
      <button
        type="button"
        class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded border border-slate-600 bg-transparent text-slate-400"
        aria-label="메뉴 열기"
        id="menu-toggle"
      >
        <span class="h-0.5 w-5 bg-current"></span>
        <span class="h-0.5 w-5 bg-current"></span>
        <span class="h-0.5 w-5 bg-current"></span>
      </button>
    </div>
  </div>

  <!-- 모바일 메뉴 -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-800 bg-[#0d0d0d] px-6 py-4 md:hidden"
  >
    <nav class="flex flex-col gap-4 text-sm">
      <a href="#contact" class="text-slate-300 hover:text-white">{siteConfig.nav.consult}</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => menu.classList.toggle("hidden"));
  }
</script>
