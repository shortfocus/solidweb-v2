---
import { siteConfig } from "@/config/site.config";
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-[#0d0d0d]">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <h3 class="font-logo text-xl font-bold text-white">{siteConfig.name}</h3>
        <p class="mt-3 text-sm text-slate-400">{siteConfig.footer.address}</p>
        <p class="mt-1 text-sm text-slate-400">{siteConfig.contact.phone}</p>
        <p class="mt-1 text-sm text-slate-400">{siteConfig.contact.email}</p>
        <p class="mt-2 text-xs text-slate-500">{siteConfig.footer.businessNumber}</p>
        <div class="mt-4 flex gap-4 text-sm">
          <a href="#" class="text-slate-500 hover:text-slate-300">{siteConfig.footer.terms}</a>
          <a href="#" class="text-slate-500 hover:text-slate-300">{siteConfig.footer.privacy}</a>
        </div>
      </div>
      <div>
        <h4 class="mb-4 text-sm font-semibold text-slate-200">서비스</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          {siteConfig.footer.services.map((s) => (
            <li><a href="#" class="hover:text-white">{s}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="mb-4 text-sm font-semibold text-slate-200">SNS</h4>
        <div class="flex gap-3 text-slate-500">
          <a href="#" class="hover:text-white" aria-label="Instagram">Instagram</a>
          <a href="#" class="hover:text-white" aria-label="Facebook">Facebook</a>
          <a href={siteConfig.kakaoChannelUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="Kakao">Kakao</a>
        </div>
      </div>
    </div>
    <div class="mt-12 border-t border-slate-800 pt-6 text-center text-sm text-slate-500">
      © {year} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>
