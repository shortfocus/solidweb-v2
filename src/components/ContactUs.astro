---
import { siteConfig } from "@/config/site.config";

const c = siteConfig.contactPage;
const ph = c.placeholders;
const lb = c.labels;
---

<section id="contact" class="min-h-screen border-t border-slate-800 bg-[#0d0d0d] py-16 md:py-24">
  <div class="mx-auto max-w-3xl px-6">
    <!-- 히어로 -->
    <div class="text-center">
      <h1 class="text-3xl font-bold text-white md:text-4xl">
        {c.heroTitle}
      </h1>
      <p class="mt-3 text-lg text-white/90">
        {c.heroSubtitle}
      </p>
      <p class="mt-2 text-sm text-slate-400">
        {c.heroDesc}
      </p>
    </div>

    <!-- 문의 폼 -->
    <form
      class="mt-14 rounded-2xl border border-slate-700/80 bg-slate-900/40 p-6 md:p-8"
      action="#"
      method="post"
      aria-label="문의하기"
    >
      <!-- 1. 방문 경로 -->
      <fieldset class="border-b border-slate-700/80 pb-6">
        <legend class="mb-4 text-sm font-semibold text-slate-200">
          {c.sections.visitPath}
        </legend>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {["검색", "지인", "기타", "온라인", "SNS", "광고"].map((value) => (
            <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-sm text-slate-300 transition hover:border-slate-500">
              <input type="radio" name="visit_path" value={value} class="h-4 w-4 border-slate-500 bg-slate-800 text-[#f43f5e] focus:ring-[#f43f5e]" />
              <span>{value}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- 2. 프로젝트 정보 -->
      <fieldset class="border-b border-slate-700/80 py-6">
        <legend class="mb-4 text-sm font-semibold text-slate-200">
          {c.sections.projectInfo}
        </legend>
        <div class="space-y-4">
          <div>
            <label for="project_name" class="sr-only">프로젝트 이름</label>
            <input
              type="text"
              id="project_name"
              name="project_name"
              placeholder={ph.projectName}
              class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
            />
          </div>
          <div>
            <span class="mb-2 block text-xs text-slate-500">프로젝트 유형</span>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
              {["앱", "솔루션", "AI", "기타"].map((value) => (
                <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-600/80 bg-slate-800/50 px-3 py-2 text-xs text-slate-300">
                  <input type="radio" name="project_type_1" value={value} class="h-3 w-3 border-slate-500 bg-slate-800 text-[#f43f5e] focus:ring-[#f43f5e]" />
                  {value}
                </label>
              ))}
            </div>
            <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
              {["웹", "데스크톱 어플리케이션", "데이터베이스", "기타"].map((value) => (
                <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-600/80 bg-slate-800/50 px-3 py-2 text-xs text-slate-300">
                  <input type="radio" name="project_type_2" value={value} class="h-3 w-3 border-slate-500 bg-slate-800 text-[#f43f5e] focus:ring-[#f43f5e]" />
                  {value}
                </label>
              ))}
            </div>
          </div>
          <div>
            <label for="project_detail" class="sr-only">프로젝트 상세</label>
            <textarea
              id="project_detail"
              name="project_detail"
              rows={5}
              placeholder={ph.projectDetail}
              class="w-full resize-y rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
            />
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="budget" class="mb-1 block text-xs text-slate-500">{lb.budget}</label>
              <input
                type="text"
                id="budget"
                name="budget"
                placeholder={ph.budget}
                class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
              />
            </div>
            <div>
              <label for="due_date" class="mb-1 block text-xs text-slate-500">{lb.dueDate}</label>
              <input
                type="date"
                id="due_date"
                name="due_date"
                class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
              />
            </div>
          </div>
        </div>
      </fieldset>

      <!-- 3. 인적사항 -->
      <fieldset class="py-6">
        <legend class="mb-4 text-sm font-semibold text-slate-200">
          {c.sections.contactInfo}
        </legend>
        <div class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="sr-only">{lb.name}</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder={ph.name}
                class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
              />
            </div>
            <div>
              <label for="company" class="sr-only">{lb.company}</label>
              <input
                type="text"
                id="company"
                name="company"
                placeholder={ph.company}
                class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
              />
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="phone" class="sr-only">{lb.phone}</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder={ph.phone}
                class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
              />
            </div>
            <div>
              <label for="position" class="sr-only">{lb.position}</label>
              <input
                type="text"
                id="position"
                name="position"
                placeholder={ph.position}
                class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
              />
            </div>
          </div>
          <div>
            <label for="email" class="sr-only">{lb.email}</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder={ph.email}
              required
              class="w-full rounded-lg border border-slate-600/80 bg-slate-800/50 px-4 py-3 text-white placeholder:text-slate-500 focus:border-[#f43f5e] focus:outline-none focus:ring-1 focus:ring-[#f43f5e]"
            />
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <label class="flex cursor-pointer items-center gap-2 text-sm text-slate-400">
              <input type="checkbox" name="privacy_consent" required class="h-4 w-4 rounded border-slate-500 bg-slate-800 text-[#f43f5e] focus:ring-[#f43f5e]" />
              <span>{lb.privacyConsent}</span>
            </label>
            <a href="#" class="privacy-open-trigger text-sm text-[#f43f5e] hover:underline">{lb.privacyView}</a>
          </div>
          <div class="pt-4">
            <button
              type="submit"
              class="w-full rounded-lg bg-slate-700 px-6 py-4 text-base font-semibold text-white transition hover:bg-[#f43f5e] focus:outline-none focus:ring-2 focus:ring-[#f43f5e] focus:ring-offset-2 focus:ring-offset-[#0d0d0d]"
            >
              {c.submitLabel}
            </button>
          </div>
        </div>
      </fieldset>
    </form>
  </div>
</section>
