---
import { siteConfig } from "@/config/site.config";
---

<section id="projects" class="border-t border-slate-800 bg-[#0d0d0d] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-2xl font-bold text-white md:text-3xl">
      {siteConfig.projects.title}
    </h2>
    <p class="mt-3 text-slate-400">
      {siteConfig.projects.subtitle}
    </p>

    <!-- Featured: ISAC Food -->
    <div class="mt-14 rounded-2xl border border-slate-800 bg-slate-900/40 p-8 md:p-12">
      <h3 class="text-2xl font-bold text-white md:text-3xl">
        {siteConfig.projects.featured.title}
      </h3>
      <p class="mt-4 max-w-2xl text-slate-400">
        {siteConfig.projects.featured.description}
      </p>
      <a
        href="#"
        class="mt-6 inline-flex rounded border border-slate-500 px-5 py-2.5 text-sm text-slate-300 hover:border-slate-400 hover:bg-slate-800/50 transition"
      >
        View Project
      </a>
    </div>

    <!-- 프로젝트 그리드 -->
    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        siteConfig.projects.items.map((p) => (
          <a
            href="#"
            class="block rounded-xl border border-slate-800 bg-slate-900/30 p-6 transition hover:border-slate-700"
          >
            <h4 class="font-semibold text-white">{p.title}</h4>
            <p class="mt-1 text-sm text-slate-500">{p.desc}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
