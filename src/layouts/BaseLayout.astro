---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PrivacyPanel from "@/components/PrivacyPanel.astro";
import { siteConfig } from "@/config/site.config";

const site = Astro.site;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const breadcrumbMap: { path: string; name: string }[] = [
  { path: "/", name: "홈" },
  { path: "/portfolio", name: "포트폴리오" },
  { path: "/contact", name: "문의하기" },
  { path: "/privacy", name: "개인정보처리방침" },
];
let breadcrumb: { path: string; name: string }[] = [{ path: "/", name: "홈" }];
const current = breadcrumbMap.find((b) => b.path === path);
if (current && current.path !== "/") breadcrumb = [{ path: "/", name: "홈" }, current];

const jsonLdGraph = site
  ? [
      {
        "@type": "Organization",
        "@id": `${site}/#organization`,
        name: siteConfig.name,
        description: siteConfig.description,
        slogan: siteConfig.hero?.subtitleMain ?? undefined,
        knowsAbout: ["웹 개발", "앱 개발", "웹사이트 제작", "브랜딩", "서비스 기획", "전환 설계"],
        url: String(site),
        logo: { "@type": "ImageObject", url: new URL("/favicon.webp", site).toString() },
        email: siteConfig.contact?.email ?? undefined,
        address: siteConfig.footer?.addressLine1
          ? {
              "@type": "PostalAddress",
              streetAddress: [siteConfig.footer.addressLine1, siteConfig.footer.addressLine2].filter(Boolean).join(" "),
              addressLocality: "인천광역시",
              addressRegion: "연수구",
            }
          : undefined,
        sameAs: siteConfig.kakaoChannelUrl ? [siteConfig.kakaoChannelUrl] : undefined,
      },
      {
        "@type": "WebSite",
        "@id": `${site}/#website`,
        name: siteConfig.name,
        description: siteConfig.description,
        url: String(site),
        publisher: { "@id": `${site}/#organization` },
        inLanguage: "ko-KR",
        potentialAction: {
          "@type": "ContactAction",
          target: { "@type": "EntryPoint", urlTemplate: String(new URL("/contact", site)) },
          contactOption: "https://schema.org/ContactPage",
        },
      },
      ...(siteConfig.whatWeDo?.items?.map((item) => ({
        "@type": "Service",
        name: item.title,
        description: item.description,
        provider: { "@id": `${site}/#organization` },
      })) ?? []),
    ]
  : [];
const jsonLdBreadcrumb = site
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumb.map((b, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: b.name,
        item: String(new URL(b.path, site)),
      })),
    }
  : null;
---

<!doctype html>
<html lang="ko">
  <head>
    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "light") document.documentElement.classList.remove("dark");
        else document.documentElement.classList.add("dark");
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Michroma&display=swap" rel="stylesheet" />
    <title>{siteConfig.name}</title>
    <meta name="description" content={siteConfig.description} />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href={Astro.site ? new URL("rss.xml", Astro.site) : "/rss.xml"} />

    <!-- Open Graph (카카오톡·네이버·페이스북·라인 등 국내·글로벌 SNS 공유) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={siteConfig.name} />
    <meta property="og:description" content={siteConfig.description} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:locale:alternate" content="en_US" />
    {Astro.site && (
      <>
        <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
        {siteConfig.ogImage && (
          <>
            <meta property="og:image" content={new URL(siteConfig.ogImage, Astro.site)} />
            <meta property="og:image:secure_url" content={new URL(siteConfig.ogImage, Astro.site)} />
            <meta property="og:image:type" content="image/webp" />
            <meta property="og:image:width" content="1200" />
            <meta property="og:image:height" content="630" />
            <meta property="og:image:alt" content={siteConfig.ogImageAlt ?? siteConfig.name} />
          </>
        )}
      </>
    )}

    <!-- Twitter Card (트위터·X 공유, 일부 SNS 폴백) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteConfig.name} />
    <meta name="twitter:description" content={siteConfig.description} />
    {Astro.site && siteConfig.ogImage && (
      <>
        <meta name="twitter:image" content={new URL(siteConfig.ogImage, Astro.site)} />
        <meta name="twitter:image:alt" content={siteConfig.ogImageAlt ?? siteConfig.name} />
      </>
    )}

    <!-- 기타 SNS·검색 (네이버·다음·구글 등) -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content={siteConfig.name} />
    <meta name="format-detection" content="telephone=no" />

    <!-- 구조화 데이터 (JSON-LD): Organization + WebSite + Service + BreadcrumbList -->
    {jsonLdGraph.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": jsonLdGraph })} />
    )}
    {jsonLdBreadcrumb && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
    )}
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-background text-foreground">
    <Header />
    <main class="flex flex-1 flex-col">
      <slot />
    </main>
    <Footer />
    <PrivacyPanel />
    <!-- 카카오톡 플로팅: 클릭 시 카카오 페이지로 바로 이동 -->
    <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3">
      <a
        href={siteConfig.kakaoChatUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-1.5 rounded-full bg-[#FEE500] px-5 py-3 text-[#191919] shadow-lg transition hover:scale-105 hover:shadow-xl"
        aria-label="톡상담"
      >
        <span class="text-sm font-bold">💬 톡상담</span>
      </a>
      <a
        href={siteConfig.kakaoChannelUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-1.5 rounded-full bg-[#FEE500] px-5 py-3 text-[#191919] shadow-lg transition hover:scale-105 hover:shadow-xl"
        aria-label="채널 추가"
      >
        <span class="text-sm font-bold">➕ 채널 추가</span>
      </a>
    </div>
  </body>
</html>
